# SmartDine Frontend — environment template
#
# Copy this file to `.env.local` for local dev (Vite reads .env.local automatically).
# For Vercel, set each of these in Project → Settings → Environment Variables
# (scope: Production + Preview). All vars MUST be prefixed VITE_ to be exposed
# to the browser.

# ── Backend API ──────────────────────────────────────────────────────────────
# The base URL of the SmartDine backend (includes /api/v1 prefix).
# Local:   http://localhost:4000/api/v1
# Render:  https://smartdine-api.onrender.com/api/v1
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Root URL of the backend (no /api prefix) — used for QR redirects, /r/:slug, /health.
VITE_PUBLIC_BASE_URL=http://localhost:4000

# Socket.IO endpoint. Same host as the backend; client picks namespaces.
VITE_SOCKET_URL=http://localhost:4000

# Where the guest QR redirect points to. In prod this is your Vercel deployment URL.
# (The backend also has its own GUEST_APP_URL env var that drives the redirect.)
VITE_GUEST_APP_URL=http://localhost:3000
